# MongoDB Atlas
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/navarmp-portfolio?retryWrites=true&w=majority

# NextAuth.js v5
AUTH_SECRET=YOUR_SECRET_KEY_HERE_GENERATE_WITH_openssl_rand_-base64_32
AUTH_URL=http://localhost:3000

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Admin Credentials (for seeding)
ADMIN_EMAIL=NavarMP@gmail.com
ADMIN_PASSWORD=your_secure_password

# File Uploads
# Directory for uploaded files (must be outside project root for git safety and PM2 compatibility)
# Default: /var/uploads/portfolio
UPLOAD_DIR=/var/uploads/portfolio

# Maximum file size in MB for uploads
# Default: 50
UPLOAD_MAX_SIZE_MB=50
